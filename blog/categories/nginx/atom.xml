</span><span class='line'><span class="no">HTML</span> <span class="ss">transferred</span><span class="p">:</span>       <span class="mi">6120000</span> <span class="n">bytes</span>
</span><span class='line'><span class="no">Requests</span> <span class="n">per</span> <span class="ss">second</span><span class="p">:</span>    <span class="mi">4466</span><span class="o">.</span><span class="mo">03</span> <span class="o">[</span><span class="c1">#/sec] (mean)</span>
